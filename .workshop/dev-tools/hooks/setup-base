set -ex

export DEBIAN_FRONTEND=noninteractive

pkgs=(
  binutils-dev
  build-essential
  autoconf
  pkg-config
  automake
  libtool
  make
  libuv1-dev
  libsqlite3-dev
  liblz4-dev
  meson
  libapparmor-dev
  libcap-dev
  libseccomp-dev
  libacl1-dev
  libudev-dev
  git
  ninja-build
  shellcheck
  jq
  xdelta3
  xfslibs-dev
)

